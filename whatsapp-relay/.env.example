# Soccer WhatsApp Relay — Environment Variables
#
# Copy to .env and fill in values. NEVER commit .env — it's gitignored.

# ── Mode (default: multi-tenant for soccer) ────────────────────
MULTI_TENANT=true
PORT=3100
DATA_DIR=./data

# ── Supabase (soccer project: jgjjnpofbpvekdvdzbgb) ────────────
# From Supabase dashboard → Settings → API
SUPABASE_URL=https://jgjjnpofbpvekdvdzbgb.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_ANON_KEY=

# ── CORS (soccer app origins) ──────────────────────────────────
ALLOWED_ORIGINS=https://streamlined-soccer.vercel.app,http://localhost:3000

# ── Single-tenant only (not used when MULTI_TENANT=true) ───────
# API_KEY=

# ── Admin (optional — operator-only endpoints) ─────────────────
# Generate: openssl rand -hex 32
# ADMIN_KEY=
